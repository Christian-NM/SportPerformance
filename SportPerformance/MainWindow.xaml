<Window x:Class="SportPerformance.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="clr-namespace:SportPerformance.Views"
        xmlns:vm="clr-namespace:SportPerformance.ViewModels"
        Title="{Binding TituloApp}" Height="650" Width="1150"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <v:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EjerciciosViewModel}">
            <v:EjerciciosView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EntrenamientosViewModel}">
            <v:EntrenamientosView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SeriesViewModel}">
            <v:SeriesView/>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="#F0F3F5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel>
                <TextBlock Text="SPORT PERFORMANCE" FontWeight="ExtraBold" Foreground="#3498DB" Margin="25,40,10,40" FontSize="18"/>
                <Button Content="  🏠   Dashboard" Command="{Binding MostrarDashboardCommand}" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="  💪   Ejercicios" Command="{Binding MostrarEjerciciosCommand}" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="  📅   Historial" Command="{Binding MostrarEntrenamientosCommand}" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="  📊   Series" Command="{Binding MostrarSeriesCommand}" Style="{StaticResource MenuButtonStyle}"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="White" Margin="20" CornerRadius="15">
            <ContentControl Content="{Binding VistaActual}" Margin="25"/>
        </Border>
    </Grid>
</Window>